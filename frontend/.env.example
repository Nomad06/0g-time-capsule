# ── Server-side (not exposed to browser) ──────────────────────────────────────

# 0G RPC for API routes
ZG_RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Storage indexer
ZG_INDEXER_URL=https://indexer-storage-testnet-standard.0g.ai

# Wallet that pays 0G storage fees (server-side only)
STORAGE_PRIVATE_KEY=0x...

# ── Client-side (NEXT_PUBLIC_ prefix) ─────────────────────────────────────────

# WalletConnect/Reown projectId — REQUIRED for mobile wallet connect (QR /
# deep-link). Free at https://cloud.reown.com. Without it only the injected
# connector is offered (desktop extension / in-app wallet browser only).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

NEXT_PUBLIC_0G_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_TIME_CAPSULE_ADDRESS=0x
NEXT_PUBLIC_KEY_REGISTRY_ADDRESS=0x
NEXT_PUBLIC_DEAD_MAN_SWITCH_ADDRESS=0x
NEXT_PUBLIC_MULTI_SIG_REVEAL_ADDRESS=0x

# Block at which TimeCapsule was deployed — set this to avoid full getLogs scans.
# Without it, /discover and /stats scan the last 500,000 blocks (may miss older capsules).
NEXT_PUBLIC_DEPLOY_BLOCK=
